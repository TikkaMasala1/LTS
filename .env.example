# ---- Local LLM ----
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi4-mini        # 16GB scenario: qwen3:14b
LTS_LLM=ollama                # or: mock

# ---- Test environment ----
LTS_MODE=simulated            # or: live

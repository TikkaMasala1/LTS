# ---- Autotask sandbox (leave empty => mock mode) ----
AUTOTASK_BASE_URL=https://webservicesX.autotask.net/ATServicesRest
AUTOTASK_INTEGRATION_CODE=
AUTOTASK_API_USER=
AUTOTASK_API_SECRET=
AUTOTASK_COMPANY_ID=0
AUTOTASK_QUEUE_ID=0

# ---- Local LLM ----
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi4-mini        # 16GB scenario: qwen3:14b
LTS_LLM=ollama                # or: mock

# ---- Test environment ----
LTS_MODE=simulated            # or: live

# --- Gemini (temporary cloud replacement; only for tests with simulated data) ---
GEMINI_API_KEY=                # via https://aistudio.google.com
GEMINI_MODEL=gemini-2.5-flash
# LTS_LLM=gemini               # enables Gemini instead of Ollama
